# ============================================================
# plantsim-agent .gitignore
# ============================================================
# This repo lives at `~/.copilot/plantsim-agent/`.
# Knowledge-base content built locally from copyrighted PTS Help
# or company-internal material lives in `kb_local/` and MUST NOT
# be pushed. See `kb_local/README.md` for the layout.
# ============================================================

# ---------- Python ----------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# Virtual environments
.venv/
venv/
ENV/
env/
.env

# pip
pip-log.txt
pip-delete-this-directory.txt

# pytest / coverage
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/
coverage.xml
*.cover
.hypothesis/

# mypy / ruff / pyright
.mypy_cache/
.dmypy.json
dmypy.json
.ruff_cache/
.pyright/

# ---------- Databases / index artefacts ----------
*.db
*.sqlite
*.sqlite3
*.db-journal

# ---------- User-built knowledge base (PRIVATE) ----------
# Everything under kb_local/ is ignored EXCEPT the README and .gitkeep
# so contributors know the folder exists and what goes there.
kb_local/*
!kb_local/README.md
!kb_local/.gitkeep

# Other local KB / index caches
.plantsim-agent/
indices/

# ---------- OneDrive / Windows ----------
desktop.ini
Thumbs.db
ehthumbs.db
ehthumbs_vista.db
$RECYCLE.BIN/
*.lnk

# ---------- macOS / Linux ----------
.DS_Store
.AppleDouble
.LSOverride
._*

# ---------- Editors ----------
.vscode/
!.vscode/settings.json.example
!.vscode/extensions.json.example
.idea/
*.swp
*.swo
*~

# ---------- Node (in case any tooling added later) ----------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ---------- Local secrets / config overrides ----------
*.local.json
*.local.yaml
*.local.toml
.env.local
.env.*.local

# ---------- Misc ----------
*.log
*.bak
*.tmp
